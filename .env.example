# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key
FINNHUB_MAX_REQUESTS_PER_MINUTE=50

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=market.quotes.raw
KAFKA_CLIENT_ID=finnhub-producer

# Producer
SYMBOLS=AAPL,MSFT,TSLA,GOOGL,AMZN
POLL_INTERVAL_SECONDS=5
REQUEST_TIMEOUT_SECONDS=10
BACKUP_CSV_PATH=data/quotes_backup.csv
DEDUP_ENABLED=true

# Consumer
CONSUMER_GROUP_ID=market-consumer-v1
CONSUMER_POLL_TIMEOUT_MS=2000
CONSUMER_FALLBACK_IDLE_SECONDS=10
CONSUMER_FALLBACK_BATCH_SIZE=200
PROCESSED_CSV_PATH=data/processed_quotes.csv

# Alertes email (SMTP)
# Gmail : créez un "mot de passe d'application" sur https://myaccount.google.com/apppasswords
SMTP_USER=votre.email@gmail.com
SMTP_PASS=mot_de_passe_application
# Optionnel (défauts = Gmail). Ex. Outlook : smtp.office365.com / 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# SMTP_FROM=votre.email@gmail.com
ALERT_ANTISPAM_MINUTES=5
